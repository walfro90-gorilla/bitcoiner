# ── Plantilla de variables de entorno (este SÍ se commitea, sin valores) ──

# Web (Next.js / Vercel) → copiar a .env.local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Muro "En construcción" (GorillaLabs). El sitio está amurallado por defecto.
#   MAINTENANCE=off  → abre el sitio real.   (sin esta línea, o cualquier otro valor, el muro está ACTIVO)
#   Para espiar detrás del muro sin apagarlo: visita cualquier URL con ?llave=<MAINTENANCE_KEY>
MAINTENANCE=off
MAINTENANCE_KEY=gorila
# LLM (copiloto + scoring de noticias). Providers: openai (compatible) | gemini | anthropic.
# Opción recomendada (gratis, rápido): Groq vía branch OpenAI-compatible.
#   LLM_PROVIDER=openai · OPENAI_API_KEY=gsk_... · OPENAI_MODEL=llama-3.3-70b-versatile
#   (OPENAI_BASE_URL por defecto = Groq; para OpenRouter/DeepSeek cambia base_url y model)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Alternativos:
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Worker (Node / UpCloud VM o Railway) → copiar a .env.worker
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=gemini
# Noticias (opcional: si no hay key, usa Google News RSS como fallback)
CRYPTOPANIC_API_KEY=
NEWS_POLL_MS=180000
# Venues / pares
WORKER_VENUES=binance,okx,kraken,bitso
WORKER_PAIRS=BTC/USDT,BTC/USD
# Riesgo / circuit breakers
MIN_NET_BPS=5
MAX_POSITION_USD=10000
MAX_BTC_PER_TRADE=0.05
MAX_TRADES_PER_MIN=30
CONSECUTIVE_LOSS_HALT=3
STALE_MS=5000
# Modelado de costos
DEPEG_BPS=8
SLIPPAGE_BPS=2
WITHDRAWAL_AMORTIZE_TRADES=50
BITSO_MXN_FEE_BPS=65
FX_SPREAD_BPS=30
# Modo maker (órdenes límite pasivas: mejor precio + fee maker, con riesgo de no-fill). Default off (taker).
MAKER_MODE=false
# Ejecución real-ready (arquitectura ExchangeAdapter). 'simulated' (default) | 'live' (Binance Spot Testnet, opt-in).
#   En 'live', el worker prueba el lifecycle real contra https://testnet.binance.vision (sin fondos reales).
EXECUTION_MODE=simulated
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=

# Replay / demo
SNAPSHOT_SAMPLE_MS=0
DEMO_MODE=false

# Reset del panel admin (route handler en Vercel). IMPORTANTE: usa un valor único, NO el default.
ADMIN_KEY=cambia-esto-por-algo-unico
